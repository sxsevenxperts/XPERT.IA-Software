# Farm-SX Environment Configuration
# This file is used for local development only
# In production, use environment variables set in EasyPanel

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/postgres

# Environment
ENV=production

# API Keys (leave empty if using EasyPanel environment variables)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Database Logging
SQL_ECHO=false
