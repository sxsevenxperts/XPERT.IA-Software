# Environment Configuration
ENV=development
DEBUG=true

# Database
DATABASE_URL=postgresql://farm_user:farm_password@localhost:5432/farm_sx_db
SQL_ECHO=false

# API
API_PORT=8000
API_HOST=0.0.0.0

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT (for future auth)
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256

# Data Collectors
CEASA_API_KEY=your_api_key
FUNCEME_API_KEY=your_api_key
IBGE_API_KEY=your_api_key

# Optional: Twilio (for WhatsApp integration)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+5585999999999
