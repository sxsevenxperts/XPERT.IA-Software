{
  "name": "Agente SDR v2.1",
  "version": "2.1",
  "description": "Workflow N8N completo para sincronização com software XPERT.IA",
  "features": [
    "multi_agent_support",
    "customizable_prompts",
    "lead_qualification",
    "objection_handling",
    "performance_logging",
    "subscription_validation",
    "token_cost_tracking"
  ],
  "nodes": [
    {
      "name": "node-webhook-whatsapp",
      "type": "webhook",
      "description": "Recebe mensagens do Evolution API (webhook)",
      "method": "POST",
      "path": "webhook/whatsapp",
      "output": {
        "from": "number_whatsapp_sender",
        "message_text": "body.text",
        "timestamp": "body.timestamp"
      }
    },
    {
      "name": "node-parse-message",
      "type": "code",
      "description": "Extrai dados da mensagem e normaliza",
      "inputs": ["node-webhook-whatsapp"],
      "logic": {
        "extract": ["phone", "text", "media_url"],
        "normalize": "lowercase text, validate phone format",
        "detect_language": "Portuguese"
      }
    },
    {
      "name": "node-lookup-session",
      "type": "supabase",
      "description": "Busca sessão existente de conversas",
      "query": "SELECT * FROM message_history WHERE numero_whatsapp = $1 ORDER BY created_at DESC LIMIT 1",
      "inputs": ["node-parse-message"],
      "returns": ["session_id", "lead_id", "user_id", "context"]
    },
    {
      "name": "node-get-or-create-lead",
      "type": "supabase",
      "description": "Cria ou busca lead correspondente",
      "logic": {
        "query": "SELECT * FROM leads WHERE user_id = $1 AND numero_whatsapp = $2",
        "if_not_found": "INSERT new lead with phone number and whatsapp stage",
        "returns": ["lead_id", "stage", "fluxo_id", "objecoes_count"]
      },
      "inputs": ["node-lookup-session"]
    },
    {
      "name": "node-validate-user",
      "type": "supabase",
      "description": "Valida autenticação e subscription do usuário",
      "query": "SELECT u.id, u.role, a.plano, a.status, a.creditos_tokens FROM profiles u JOIN assinaturas a ON u.id = a.user_id WHERE u.id = $1",
      "checks": {
        "subscription_active": "assinaturas.status = 'active'",
        "tokens_available": "creditos_tokens > 0",
        "account_not_suspended": "NOT (assinaturas.status = 'suspended')"
      },
      "inputs": ["node-get-or-create-lead"],
      "error_response": "Subscription inativa ou tokens zerados"
    },
    {
      "name": "node-detect-agent-type",
      "type": "code",
      "description": "Detecta qual agente deve responder (principal, objeção, extra)",
      "logic": {
        "check_lead_stage": "if lead.stage = 'objecoes' then agent=objecao else agent=principal",
        "check_objection_count": "if objecoes_count > 2 then agent=objecao",
        "check_user_addons": "if addon_agente_extra active then agent=extra",
        "agent_index": "ae0, ae1, etc for extras"
      },
      "inputs": ["node-validate-user"],
      "outputs": ["agent_type", "agent_index"]
    },
    {
      "name": "node-busca-configs-sdr",
      "type": "supabase_rest",
      "description": "Busca configurações customizadas do agente do software",
      "method": "GET",
      "endpoint": "agente_config?user_id=eq.{user_id}&chave=in.(sistema_prompt,tonalidade,criterios_qualificacao)",
      "headers": {
        "Authorization": "Bearer {jwt_token}",
        "apikey": "{supabase_api_key}"
      },
      "inputs": ["node-detect-agent-type"],
      "returns": {
        "sistema_prompt": "custom system prompt or fallback",
        "ob_sistema_prompt": "for objection agent",
        "ae0_sistema_prompt": "for extra agent 0",
        "tonalidade": "tone of voice setting",
        "criterios_qualificacao": "qualification criteria"
      }
    },
    {
      "name": "node-build-system-prompt",
      "type": "code",
      "description": "Monta system prompt final com prefixos por agente",
      "logic": {
        "if_agent_principal": "use sistema_prompt or PROMPT_PADRAO_PRINCIPAL",
        "if_agent_objecao": "use ob_sistema_prompt or PROMPT_PADRAO_OBJECAO",
        "if_agent_extra": "use ae{index}_sistema_prompt or PROMPT_PADRAO_EXTRA",
        "append_tonalidade": "add tonalidade setting to prompt",
        "append_criterios": "add qualification criteria to prompt"
      },
      "inputs": ["node-busca-configs-sdr"],
      "outputs": ["final_system_prompt"]
    },
    {
      "name": "node-load-conversation-history",
      "type": "supabase",
      "description": "Carrega histórico de conversas para context",
      "query": "SELECT conteudo, sender FROM message_history WHERE lead_id = $1 AND user_id = $2 ORDER BY created_at DESC LIMIT 10",
      "inputs": ["node-build-system-prompt"],
      "outputs": ["conversation_context"]
    },
    {
      "name": "node-llm-openai",
      "type": "openai",
      "description": "Chama OpenAI GPT-4 com prompt customizado",
      "inputs": ["node-load-conversation-history"],
      "config": {
        "model": "gpt-4",
        "temperature": 0.7,
        "max_tokens": 500,
        "system": "{final_system_prompt}",
        "messages": [
          { "role": "system", "content": "{final_system_prompt}" },
          { "role": "user", "content": "{conversation_context}\\n\\nNova mensagem: {message_text}" }
        ]
      },
      "output_processing": {
        "response_text": "choices[0].message.content",
        "tokens_input": "usage.prompt_tokens",
        "tokens_output": "usage.completion_tokens",
        "model_used": "model",
        "time_ms": "measure duration"
      }
    },
    {
      "name": "node-detect-qualification",
      "type": "code",
      "description": "Detecta se lead foi qualificado ou desqualificado",
      "logic": {
        "analyze_response": "check if response contains qualification markers",
        "matched_criteria": "count how many criteria were met",
        "qualification_score": "calculate score from 0-100",
        "decision": "if score > threshold then qualified else unqualified"
      },
      "inputs": ["node-llm-openai"],
      "outputs": ["qualified", "qualification_score", "criteria_matched"]
    },
    {
      "name": "node-detect-objections",
      "type": "code",
      "description": "Detecta objeções na resposta do lead",
      "logic": {
        "nlp_analysis": "analyze response for objection keywords",
        "objection_types": ["price", "timing", "competitor", "other"],
        "objection_count": "increment lead.objecoes_count",
        "suggestion": "generate objection handling strategy"
      },
      "inputs": ["node-llm-openai"],
      "outputs": ["has_objection", "objection_type", "handling_strategy"]
    },
    {
      "name": "node-save-response-log",
      "type": "supabase",
      "description": "Salva resposta do agente no histórico",
      "table": "message_history",
      "data": {
        "user_id": "{user_id}",
        "lead_id": "{lead_id}",
        "numero_whatsapp": "{phone_number}",
        "sender": "assistant",
        "conteudo": "{response_text}",
        "tokens_usados": "{tokens_output}",
        "agent_type": "{agent_type}",
        "timestamp": "now()"
      },
      "inputs": ["node-detect-objections"]
    },
    {
      "name": "node-send-whatsapp",
      "type": "evolution_api",
      "description": "Envia resposta via WhatsApp",
      "endpoint": "message/sendText",
      "data": {
        "chatId": "{phone_number}",
        "text": "{response_text}"
      },
      "inputs": ["node-save-response-log"],
      "headers": {
        "Authorization": "Bearer {evolution_api_token}"
      }
    },
    {
      "name": "node-update-lead",
      "type": "supabase",
      "description": "Atualiza status do lead conforme resultado",
      "logic": {
        "if_qualified": "UPDATE leads SET stage = 'qualified', ultima_pergunta = $1, updated_at = now()",
        "if_objection": "UPDATE leads SET objecoes_count = objecoes_count + 1, updated_at = now()",
        "if_unqualified": "UPDATE leads SET stage = 'unqualified', updated_at = now()"
      },
      "inputs": ["node-detect-qualification", "node-detect-objections"]
    },
    {
      "name": "node-route-to-supervisor",
      "type": "conditional",
      "description": "Roteia para supervisor se qualificado",
      "condition": "if qualified and lead.stage = 'qualified'",
      "actions": {
        "send_notification": "POST to WhatsApp supervisor number with lead summary",
        "update_lead_status": "SET aguardando_resposta = true"
      },
      "inputs": ["node-detect-qualification"]
    },
    {
      "name": "node-update-tokens",
      "type": "supabase",
      "description": "Decrementa tokens e atualiza saldo",
      "logic": {
        "total_tokens": "{tokens_input} + {tokens_output}",
        "UPDATE assinaturas SET creditos_tokens = creditos_tokens - {total_tokens} WHERE user_id = {user_id}"
      },
      "inputs": ["node-llm-openai"]
    },
    {
      "name": "node-log-execution",
      "type": "edge_function",
      "description": "Registra execução do workflow no Supabase para monitoramento",
      "endpoint": "https://vyvdrbkcrvklcaombjqu.supabase.co/functions/v1/log-workflow-execution",
      "method": "POST",
      "headers": {
        "Authorization": "Bearer {jwt_token}",
        "Content-Type": "application/json"
      },
      "payload": {
        "user_id": "{user_id}",
        "lead_id": "{lead_id}",
        "agent_type": "{agent_type}",
        "agent_index": "{agent_index}",
        "duracao_ms": "{workflow_duration}",
        "status": "sucesso|erro|timeout",
        "tokens_input": "{tokens_input}",
        "tokens_output": "{tokens_output}",
        "modelo_usado": "gpt-4",
        "resposta_gerada": "{response_text}",
        "numero_whatsapp": "{phone_number}",
        "erro_mensagem": null,
        "erro_tipo": null
      },
      "inputs": ["node-update-tokens", "node-send-whatsapp"],
      "retry_on_failure": true,
      "error_handling": "Log errors but don't block workflow"
    }
  ],
  "configuration": {
    "environment_variables": {
      "SUPABASE_URL": "https://vyvdrbkcrvklcaombjqu.supabase.co",
      "SUPABASE_API_KEY": "{set_in_n8n_credentials}",
      "OPENAI_API_KEY": "{set_in_n8n_credentials}",
      "EVOLUTION_API_URL": "{set_in_n8n_credentials}",
      "EVOLUTION_API_TOKEN": "{set_in_n8n_credentials}",
      "JWT_SECRET": "{set_in_n8n_credentials}"
    },
    "timeouts": {
      "openai_call": 30000,
      "supabase_query": 10000,
      "evolution_send": 15000,
      "workflow_total": 120000
    },
    "error_handling": {
      "retry_failed_nodes": true,
      "max_retries": 2,
      "backoff_ms": 1000,
      "fail_silently_for": ["node-log-execution"]
    }
  },
  "changelog": {
    "v2.1": {
      "date": "2026-03-19",
      "changes": [
        "✅ Sincronização com tabela agente_config usando prefixos (sistema_prompt, ob_sistema_prompt, ae{index}_sistema_prompt)",
        "✅ Node 'node-busca-configs-sdr' busca todas as configs customizadas",
        "✅ Node 'node-build-system-prompt' monta prompt final com todas as customizações",
        "✅ Node 'node-log-execution' envia logs para edge function de monitoramento",
        "✅ Token tracking em todos os agentes (principal, objeção, extra)",
        "✅ Suporte a múltiplos agentes extras com índices (ae0, ae1, ae2, etc)",
        "✅ Validação de subscription em node-validate-user",
        "✅ Error handling robusto para timeouts e API failures"
      ]
    },
    "v2.0": {
      "date": "2026-03-15",
      "changes": [
        "Initial release with multi-agent support",
        "Lead qualification and objection handling",
        "WhatsApp integration via Evolution API",
        "OpenAI GPT-4 integration",
        "Supabase data persistence"
      ]
    }
  },
  "integration_notes": {
    "software_sync": "All agent configurations stored in agente_config table and synced via node-busca-configs-sdr",
    "customization_fields": [
      "sistema_prompt (principal agent)",
      "ob_sistema_prompt (objection agent)",
      "ae{index}_sistema_prompt (extra agents)",
      "tonalidade (tone of voice)",
      "criterios_qualificacao (qualification criteria)",
      "msg_qualificado (qualified message)",
      "msg_desqualificado (unqualified message)"
    ],
    "monitoring": "All executions logged to workflow_executions table via edge function",
    "token_tracking": "Input and output tokens tracked per execution and aggregated for billing"
  }
}