{
  "name": "Agente SDR v2.3",
  "version": "2.3",
  "description": "Workflow N8N completo — multi-agente (principal, prospecção, objeção, extras), modelo de IA dinâmico por agente, configs 100% do software",
  "features": [
    "multi_agent_support",
    "agente_prospecao",
    "dynamic_ai_model_per_agent",
    "dynamic_provider_openai_claude_google",
    "customizable_prompts",
    "lead_qualification",
    "objection_handling",
    "performance_logging",
    "subscription_validation",
    "token_cost_tracking",
    "dynamic_routing",
    "tts_audio_response",
    "payment_gateway_integration",
    "agent_name_override"
  ],
  "nodes": [
    {
      "name": "node-webhook-whatsapp",
      "type": "webhook",
      "description": "Recebe mensagens do Evolution API",
      "method": "POST",
      "path": "webhook/whatsapp",
      "output": {
        "from": "number_whatsapp_sender",
        "message_text": "body.text",
        "media_type": "body.mediaType",
        "media_url": "body.mediaUrl",
        "timestamp": "body.timestamp"
      }
    },
    {
      "name": "node-parse-message",
      "type": "code",
      "description": "Extrai e normaliza dados da mensagem recebida",
      "inputs": ["node-webhook-whatsapp"],
      "logic": {
        "extract": ["phone", "text", "media_url", "media_type"],
        "normalize": "lowercase text, validate phone format",
        "detect_language": "Portuguese"
      }
    },
    {
      "name": "node-lookup-session",
      "type": "supabase",
      "description": "Busca sessão existente de conversas",
      "query": "SELECT * FROM message_history WHERE numero_whatsapp = $1 ORDER BY created_at DESC LIMIT 1",
      "inputs": ["node-parse-message"],
      "returns": ["session_id", "lead_id", "user_id", "context"]
    },
    {
      "name": "node-get-or-create-lead",
      "type": "supabase",
      "description": "Cria ou busca lead correspondente ao número",
      "logic": {
        "query": "SELECT * FROM leads WHERE user_id = $1 AND numero_whatsapp = $2",
        "if_not_found": "INSERT new lead with phone number and whatsapp stage",
        "returns": ["lead_id", "stage", "fluxo_id", "objecoes_count"]
      },
      "inputs": ["node-lookup-session"]
    },
    {
      "name": "node-validate-user",
      "type": "supabase",
      "description": "Valida autenticação e subscription do usuário",
      "query": "SELECT u.id, u.role, a.plano, a.status, a.creditos_tokens, a.addon_objecao, a.agentes_extras FROM profiles u JOIN assinaturas a ON u.id = a.user_id WHERE u.id = $1",
      "checks": {
        "subscription_active": "assinaturas.status = 'active'",
        "tokens_available": "creditos_tokens > 0",
        "account_not_suspended": "NOT (assinaturas.status = 'suspended')"
      },
      "inputs": ["node-get-or-create-lead"],
      "error_response": "Sua assinatura está inativa ou saldo de tokens zerado."
    },
    {
      "name": "node-detect-agent-type",
      "type": "code",
      "description": "Detecta qual agente deve responder: principal, prospecção, objeção ou extra",
      "logic": {
        "check_lead_stage_prospecao": "if lead.stage = 'prospecao' OR fluxo_id includes 'prospec' → agent = prospec",
        "check_lead_stage_objecao": "if lead.stage = 'objecoes' → agent = objecao",
        "check_objection_count": "if objecoes_count > 2 → agent = objecao",
        "check_user_addons_extra": "if addon_agente_extra active AND fluxo_id matches ae{n} → agent = extra",
        "default": "agent = principal",
        "agent_index": "ae0, ae1, ae2… para extras; 0 para principal/prospec/objecao"
      },
      "inputs": ["node-validate-user"],
      "outputs": ["agent_type", "agent_index"]
    },

    {
      "name": "node-busca-configs-sdr",
      "type": "supabase_rest",
      "description": "Busca TODAS as configurações do software (agente_config) — prompts, modelos, tonalidade, critérios, roteamento e gateways",
      "method": "GET",
      "endpoint": "agente_config?user_id=eq.{user_id}&chave=in.(sistema_prompt,ob_sistema_prompt,prospec_sistema_prompt,ae0_sistema_prompt,ae1_sistema_prompt,ae2_sistema_prompt,tonalidade,ob_tonalidade,prospec_tonalidade,criterios_qualificacao,ob_criterios_qualificacao,prospec_criterios_qualificacao,msg_qualificado,ob_msg_qualificado,prospec_msg_qualificado,msg_desqualificado,ob_msg_desqualificado,prospec_msg_desqualificado,responder_em_audio,ob_responder_em_audio,prospec_responder_em_audio,numero_destino,ob_numero_destino,prospec_numero_destino,grupo_destino,ob_grupo_destino,prospec_grupo_destino,notif_destino,ai_provider,ob_ai_provider,prospec_ai_provider,ae0_ai_provider,ae1_ai_provider,ae2_ai_provider,openai_model,openai_temperature,openai_max_tokens,ob_openai_model,ob_openai_temperature,ob_openai_max_tokens,prospec_openai_model,prospec_openai_temperature,prospec_openai_max_tokens,ae0_openai_model,ae1_openai_model,claude_model,claude_temperature,claude_max_tokens,ob_claude_model,ob_claude_temperature,ob_claude_max_tokens,prospec_claude_model,prospec_claude_temperature,prospec_claude_max_tokens,google_model,google_temperature,google_max_tokens,ob_google_model,ob_google_temperature,ob_google_max_tokens,prospec_google_model,prospec_google_temperature,prospec_google_max_tokens,nome_agente,ob_nome_agente,prospec_nome_agente,gateway_padrao,fallback-mercado_pago,fallback-asaas,fallback-infinitepay)",
      "headers": {
        "Authorization": "Bearer {jwt_token}",
        "apikey": "{supabase_api_key}"
      },
      "inputs": ["node-detect-agent-type"],
      "post_processing": {
        "description": "Converte array [{chave, valor}] em objeto configMap",
        "code": "const configMap = {}; items.forEach(i => { configMap[i.chave] = i.valor; }); return configMap;"
      },
      "returns": {
        "sistema_prompt": "Prompt do Agente Principal",
        "ob_sistema_prompt": "Prompt do Agente de Objeção",
        "prospec_sistema_prompt": "Prompt do Agente de Prospecção",
        "ae{n}_sistema_prompt": "Prompt dos Agentes Extras",
        "tonalidade / ob_tonalidade / prospec_tonalidade": "Tom de voz por agente",
        "criterios_qualificacao / ob_ / prospec_": "Critérios de triagem por agente",
        "msg_qualificado / ob_ / prospec_": "Mensagem ao lead qualificado por agente",
        "msg_desqualificado / ob_ / prospec_": "Mensagem ao lead desqualificado por agente",
        "responder_em_audio / ob_ / prospec_": "'true'|'false' — TTS por agente",
        "numero_destino / ob_ / prospec_": "Supervisor de notificações por agente",
        "grupo_destino / ob_ / prospec_": "Grupo WhatsApp de notificações por agente",
        "notif_destino": "'numero'|'grupo'|'ambos'",
        "ai_provider / ob_ / prospec_ / ae{n}_": "'openai'|'claude'|'google' por agente",
        "openai_model / ob_ / prospec_ / ae{n}_": "Modelo OpenAI por agente (ex: gpt-4o-mini)",
        "openai_temperature / ob_ / prospec_": "Temperature OpenAI por agente (0–2)",
        "openai_max_tokens / ob_ / prospec_": "Max tokens OpenAI por agente",
        "claude_model / ob_ / prospec_": "Modelo Claude por agente (ex: claude-haiku-4-5)",
        "claude_temperature / ob_ / prospec_": "Temperature Claude por agente (0–1)",
        "claude_max_tokens / ob_ / prospec_": "Max tokens Claude por agente",
        "google_model / ob_ / prospec_": "Modelo Gemini por agente (ex: gemini-2.0-flash)",
        "google_temperature / ob_ / prospec_": "Temperature Google por agente (0–2)",
        "google_max_tokens / ob_ / prospec_": "Max tokens Google por agente",
        "nome_agente / ob_ / prospec_": "Nome personalizado do agente (informativo)",
        "gateway_padrao": "'stripe'|'mercado_pago'|'asaas'|'infinitepay'",
        "fallback-*": "'true'|'false' — gateways de fallback"
      }
    },

    {
      "name": "node-build-system-prompt",
      "type": "code",
      "description": "Monta system prompt + seleciona provider e modelo dinâmico baseado no agente ativo e configs do software",
      "inputs": ["node-busca-configs-sdr"],
      "logic": {
        "step_1_select_base_prompt": {
          "if_agent_principal": "configMap.sistema_prompt || PROMPT_PADRAO_PRINCIPAL",
          "if_agent_prospecao": "configMap.prospec_sistema_prompt || PROMPT_PADRAO_PROSPECAO",
          "if_agent_objecao": "configMap.ob_sistema_prompt || PROMPT_PADRAO_OBJECAO",
          "if_agent_extra": "configMap[`ae${agent_index}_sistema_prompt`] || PROMPT_PADRAO_EXTRA"
        },
        "step_2_select_prefix": {
          "principal": "prefix = ''",
          "prospec": "prefix = 'prospec_'",
          "objecao": "prefix = 'ob_'",
          "extra": "prefix = `ae${agent_index}_`"
        },
        "step_3_select_provider": {
          "logic": "provider = configMap[`${prefix}ai_provider`] || configMap.ai_provider || 'openai'",
          "options": ["openai", "claude", "google"]
        },
        "step_4_select_model_params": {
          "if_openai": {
            "model": "configMap[`${prefix}openai_model`] || configMap.openai_model || 'gpt-4o-mini'",
            "temperature": "parseFloat(configMap[`${prefix}openai_temperature`] || configMap.openai_temperature || '0.7')",
            "max_tokens": "parseInt(configMap[`${prefix}openai_max_tokens`] || configMap.openai_max_tokens || '1024')"
          },
          "if_claude": {
            "model": "configMap[`${prefix}claude_model`] || configMap.claude_model || 'claude-haiku-4-5'",
            "temperature": "parseFloat(configMap[`${prefix}claude_temperature`] || configMap.claude_temperature || '0.7')",
            "max_tokens": "parseInt(configMap[`${prefix}claude_max_tokens`] || configMap.claude_max_tokens || '1024')"
          },
          "if_google": {
            "model": "configMap[`${prefix}google_model`] || configMap.google_model || 'gemini-2.0-flash'",
            "temperature": "parseFloat(configMap[`${prefix}google_temperature`] || configMap.google_temperature || '0.7')",
            "max_tokens": "parseInt(configMap[`${prefix}google_max_tokens`] || configMap.google_max_tokens || '1024')"
          }
        },
        "step_5_append_tonalidade": {
          "key": "${prefix}tonalidade",
          "action": "if set → append '\\n\\nTONALIDADE: {value}' to prompt"
        },
        "step_6_append_criterios": {
          "key": "${prefix}criterios_qualificacao",
          "action": "if set → append '\\n\\nCRITÉRIOS DE QUALIFICAÇÃO:\\n{value}' to prompt"
        }
      },
      "outputs": [
        "final_system_prompt",
        "ai_provider_ativo",
        "ai_model_ativo",
        "ai_temperature_ativo",
        "ai_max_tokens_ativo",
        "msg_qualificado",
        "msg_desqualificado",
        "responder_em_audio",
        "numero_destino",
        "grupo_destino",
        "notif_destino",
        "gateway_padrao"
      ]
    },

    {
      "name": "node-load-conversation-history",
      "type": "supabase",
      "description": "Carrega histórico de conversas para contexto do LLM",
      "query": "SELECT conteudo, sender FROM message_history WHERE lead_id = $1 AND user_id = $2 ORDER BY created_at DESC LIMIT 10",
      "inputs": ["node-build-system-prompt"],
      "outputs": ["conversation_context"]
    },

    {
      "name": "node-llm-openai",
      "type": "http_request",
      "description": "Chama llm-proxy com provider, modelo e parâmetros dinâmicos do software — suporta OpenAI, Claude (Anthropic) e Google (Gemini)",
      "method": "POST",
      "endpoint": "https://vyvdrbkcrvklcaombjqu.supabase.co/functions/v1/llm-proxy",
      "headers": {
        "Authorization": "Bearer {jwt_token}",
        "Content-Type": "application/json"
      },
      "payload": {
        "provider": "{ai_provider_ativo}",
        "model": "{ai_model_ativo}",
        "temperature": "{ai_temperature_ativo}",
        "max_tokens": "{ai_max_tokens_ativo}",
        "messages": [
          { "role": "system", "content": "{final_system_prompt}" },
          { "role": "user", "content": "{conversation_context}\n\nNova mensagem do lead: {message_text}" }
        ],
        "user_id": "{user_id}"
      },
      "inputs": ["node-load-conversation-history"],
      "output_processing": {
        "response_text": "choices[0].message.content",
        "tokens_input": "usage.prompt_tokens",
        "tokens_output": "usage.completion_tokens",
        "model_used": "model"
      },
      "notes": "llm-proxy suporta provider='openai'|'claude'|'google' e roteia para a API correta. As chaves de API são configuradas por agente no software (Modelo de IA → salvas em agente_config) e lidas pelo llm-proxy via SUPABASE_SERVICE_ROLE_KEY."
    },

    {
      "name": "node-detect-qualification",
      "type": "code",
      "description": "Detecta qualificação ou desqualificação do lead pela resposta do LLM",
      "inputs": ["node-llm-openai"],
      "logic": {
        "check_markers": "Verifica marcadores [LEAD_QUALIFICADO] / [LEAD_DESQUALIFICADO] na resposta",
        "fallback_score": "Se não houver marcador, calcula score pelos critérios de qualificação",
        "decision": "qualified = true | false"
      },
      "outputs": ["qualified", "disqualified", "qualification_score"]
    },

    {
      "name": "node-detect-objections",
      "type": "code",
      "description": "Detecta objeções na mensagem do lead",
      "inputs": ["node-llm-openai"],
      "logic": {
        "nlp_analysis": "Analisa resposta por palavras-chave de objeção",
        "objection_types": ["preco", "timing", "concorrente", "outro"],
        "suggestion": "Gera estratégia de contorno via ob_sistema_prompt"
      },
      "outputs": ["has_objection", "objection_type", "handling_strategy"]
    },

    {
      "name": "node-decide-response-format",
      "type": "code",
      "description": "Decide se resposta será texto ou áudio (TTS) com base em responder_em_audio do agente ativo",
      "inputs": ["node-detect-qualification", "node-detect-objections"],
      "logic": {
        "check_audio_flag": "if responder_em_audio === 'true' → format = 'audio' else format = 'text'",
        "if_audio": "POST para evo-proxy com endpoint send-audio",
        "if_text": "POST para evo-proxy com endpoint send-text"
      },
      "outputs": ["response_format"]
    },

    {
      "name": "node-send-whatsapp",
      "type": "http_request",
      "description": "Envia resposta via evo-proxy (texto ou áudio TTS)",
      "method": "POST",
      "endpoint": "https://vyvdrbkcrvklcaombjqu.supabase.co/functions/v1/evo-proxy",
      "headers": {
        "Authorization": "Bearer {jwt_token}",
        "Content-Type": "application/json"
      },
      "payload_text": {
        "action": "send-text",
        "instance": "{evo_instance}",
        "chatId": "{phone_number}",
        "text": "{response_text}"
      },
      "payload_audio": {
        "action": "send-audio",
        "instance": "{evo_instance}",
        "chatId": "{phone_number}",
        "text": "{response_text}"
      },
      "inputs": ["node-decide-response-format"]
    },

    {
      "name": "node-send-qualified-message",
      "type": "http_request",
      "description": "Envia msg_qualificado ou msg_desqualificado configurado no software para o agente ativo",
      "condition": "if qualified === true OR disqualified === true",
      "method": "POST",
      "endpoint": "https://vyvdrbkcrvklcaombjqu.supabase.co/functions/v1/evo-proxy",
      "headers": {
        "Authorization": "Bearer {jwt_token}",
        "Content-Type": "application/json"
      },
      "payload": {
        "action": "send-text",
        "instance": "{evo_instance}",
        "chatId": "{phone_number}",
        "text": "if qualified → msg_qualificado || 'Parabéns! Você foi qualificado.'\n       if disqualified → msg_desqualificado || 'Obrigado pelo contato.'"
      },
      "inputs": ["node-detect-qualification"]
    },

    {
      "name": "node-route-to-supervisor",
      "type": "conditional",
      "description": "Notifica supervisor quando lead é qualificado — usa numero_destino/grupo_destino/notif_destino do agente ativo",
      "condition": "qualified === true",
      "inputs": ["node-detect-qualification"],
      "routing": {
        "notif_destino_numero": {
          "condition": "notif_destino === 'numero' OR notif_destino === 'ambos'",
          "action": "POST evo-proxy send-text → numero_destino",
          "payload": {
            "action": "send-text",
            "instance": "{evo_instance}",
            "chatId": "{numero_destino}@s.whatsapp.net",
            "text": "🎯 *Novo lead qualificado!*\n\n*Nome:* {lead_nome}\n*Telefone:* {phone_number}\n*Agente:* {agent_type}\n*Score:* {qualification_score}/100\n*Última mensagem:* {message_text}"
          }
        },
        "notif_destino_grupo": {
          "condition": "notif_destino === 'grupo' OR notif_destino === 'ambos'",
          "action": "POST evo-proxy send-text → grupo_destino",
          "payload": {
            "action": "send-text",
            "instance": "{evo_instance}",
            "chatId": "{grupo_destino}",
            "text": "🎯 *Novo lead qualificado!*\n\n*Nome:* {lead_nome}\n*Telefone:* {phone_number}\n*Agente:* {agent_type}\n*Score:* {qualification_score}/100"
          }
        }
      },
      "after": "UPDATE leads SET aguardando_resposta = true WHERE id = {lead_id}"
    },

    {
      "name": "node-save-response-log",
      "type": "supabase",
      "description": "Persiste mensagem do agente no histórico de conversas",
      "table": "message_history",
      "data": {
        "user_id": "{user_id}",
        "lead_id": "{lead_id}",
        "numero_whatsapp": "{phone_number}",
        "sender": "assistant",
        "conteudo": "{response_text}",
        "tokens_usados": "{tokens_output}",
        "agent_type": "{agent_type}",
        "timestamp": "now()"
      },
      "inputs": ["node-send-whatsapp"]
    },

    {
      "name": "node-update-lead",
      "type": "supabase",
      "description": "Atualiza estágio e contadores do lead",
      "logic": {
        "if_qualified": "UPDATE leads SET stage = 'qualified', updated_at = now()",
        "if_disqualified": "UPDATE leads SET stage = 'unqualified', updated_at = now()",
        "if_objection": "UPDATE leads SET objecoes_count = objecoes_count + 1, updated_at = now()",
        "always": "UPDATE leads SET ultima_pergunta = {message_text}, updated_at = now()"
      },
      "inputs": ["node-detect-qualification", "node-detect-objections"]
    },

    {
      "name": "node-update-tokens",
      "type": "supabase",
      "description": "Decrementa saldo de tokens na assinatura do usuário",
      "query": "UPDATE assinaturas SET creditos_tokens = creditos_tokens - {tokens_total} WHERE user_id = '{user_id}'",
      "logic": {
        "tokens_total": "{tokens_input} + {tokens_output}"
      },
      "inputs": ["node-llm-openai"]
    },

    {
      "name": "node-log-execution",
      "type": "http_request",
      "description": "Registra execução no dashboard de monitoramento (edge function log-workflow-execution)",
      "method": "POST",
      "endpoint": "https://vyvdrbkcrvklcaombjqu.supabase.co/functions/v1/log-workflow-execution",
      "headers": {
        "Authorization": "Bearer {jwt_token}",
        "Content-Type": "application/json"
      },
      "payload": {
        "user_id": "{user_id}",
        "lead_id": "{lead_id}",
        "agent_type": "{agent_type}",
        "agent_index": "{agent_index}",
        "duracao_ms": "{workflow_duration_ms}",
        "status": "sucesso",
        "tokens_input": "{tokens_input}",
        "tokens_output": "{tokens_output}",
        "modelo_usado": "{ai_model_ativo}",
        "resposta_gerada": "{response_text}",
        "numero_whatsapp": "{phone_number}",
        "erro_mensagem": null
      },
      "inputs": ["node-update-tokens", "node-save-response-log"],
      "error_handling": "fail_silently — nunca bloqueia o workflow"
    },

    {
      "name": "node-detect-payment-intent",
      "type": "code",
      "description": "Detecta se o lead expressou intenção de pagar na mensagem",
      "inputs": ["node-llm-openai"],
      "logic": {
        "keywords": ["quero pagar", "como pago", "vou fechar", "quero comprar", "valor", "boleto", "pix", "cartão", "parcelas"],
        "llm_marker": "Verifica se resposta do LLM contém [INICIAR_PAGAMENTO]",
        "decision": "payment_intent = true | false"
      },
      "outputs": ["payment_intent"]
    },

    {
      "name": "node-busca-gateway-config",
      "type": "supabase_rest",
      "description": "Busca credenciais dos gateways de pagamento configurados pelo cliente",
      "condition": "payment_intent === true",
      "method": "GET",
      "endpoint": "agente_config?user_id=eq.{user_id}&chave=in.(gateway_padrao,stripe_publishable,stripe_secret,stripe_webhook,mercado_pago_access,mercado_pago_public,asaas_api_key,asaas_account_id,infinitepay_api_key,infinitepay_public,fallback-mercado_pago,fallback-asaas,fallback-infinitepay)",
      "headers": {
        "Authorization": "Bearer {jwt_token}",
        "apikey": "{supabase_api_key}"
      },
      "inputs": ["node-detect-payment-intent"],
      "post_processing": "Converte array em gatewayMap"
    },

    {
      "name": "node-create-payment",
      "type": "http_request",
      "description": "Cria cobrança no gateway configurado pelo cliente via edge function",
      "condition": "payment_intent === true AND gateway_padrao is set",
      "method": "POST",
      "endpoint_logic": {
        "stripe": "https://vyvdrbkcrvklcaombjqu.supabase.co/functions/v1/payment-stripe",
        "mercado_pago": "https://vyvdrbkcrvklcaombjqu.supabase.co/functions/v1/payment-mercado-pago",
        "asaas": "https://vyvdrbkcrvklcaombjqu.supabase.co/functions/v1/payment-asaas",
        "infinitepay": "https://vyvdrbkcrvklcaombjqu.supabase.co/functions/v1/payment-infinitepay"
      },
      "headers": {
        "Authorization": "Bearer {jwt_token}",
        "Content-Type": "application/json"
      },
      "payload": {
        "user_id": "{user_id}",
        "lead_id": "{lead_id}",
        "lead_email": "{lead_email}",
        "lead_nome": "{lead_nome}",
        "amount_cents": "{valor_cobranca}",
        "currency": "BRL",
        "description": "{descricao_produto}",
        "gateway_credentials": "{gatewayMap}"
      },
      "inputs": ["node-busca-gateway-config"],
      "fallback": {
        "description": "Se o gateway padrão falhar, tenta fallbacks na ordem configurada",
        "order": "fallback-mercado_pago → fallback-asaas → fallback-infinitepay"
      },
      "outputs": ["payment_url", "payment_id", "gateway_usado"]
    },

    {
      "name": "node-send-payment-link",
      "type": "http_request",
      "description": "Envia o link de pagamento ao lead via WhatsApp",
      "condition": "payment_intent === true AND payment_url is set",
      "method": "POST",
      "endpoint": "https://vyvdrbkcrvklcaombjqu.supabase.co/functions/v1/evo-proxy",
      "headers": {
        "Authorization": "Bearer {jwt_token}",
        "Content-Type": "application/json"
      },
      "payload": {
        "action": "send-text",
        "instance": "{evo_instance}",
        "chatId": "{phone_number}",
        "text": "💳 *Seu link de pagamento está pronto!*\n\nClique para pagar com segurança:\n{payment_url}\n\n_Link válido por 24 horas._"
      },
      "inputs": ["node-create-payment"]
    }
  ],

  "flow_diagram": {
    "description": "Fluxo completo do workflow v2.3",
    "sequence": [
      "webhook → parse → lookup-session → get-or-create-lead → validate-user",
      "→ detect-agent-type (principal | prospec | objecao | extra)",
      "→ busca-configs-sdr (prompts + modelos + tonalidade + roteamento)",
      "→ build-system-prompt (seleciona provider/modelo/temperatura dinâmico)",
      "→ load-conversation-history → llm-openai (OpenAI | Claude | Google)",
      "→ [parallel] detect-qualification + detect-objections + detect-payment-intent",
      "→ decide-response-format → send-whatsapp (texto ou áudio TTS)",
      "→ [if qualified] send-qualified-message + route-to-supervisor",
      "→ [if payment_intent] busca-gateway-config → create-payment → send-payment-link",
      "→ save-response-log → update-lead → update-tokens → log-execution"
    ]
  },

