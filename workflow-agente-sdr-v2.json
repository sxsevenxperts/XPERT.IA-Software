{
  "name": "Agente SDR - Qualificação e Roteamento de Leads (v2.1)",
  "description": "Workflow de SDR automático com suporte a múltiplos agentes, qualificação de leads, detecção de objeções e roteamento inteligente",
  "version": "2.1",
  "updated_at": "2026-03-19T15:30:00Z",
  "status": "production",
  "nodes": [
    {
      "id": "node-webhook-whatsapp",
      "type": "webhook",
      "name": "Webhook - Nova Mensagem WhatsApp",
      "position": [0, 0],
      "description": "Recebe mensagens do Evolution API quando um lead entra em contato",
      "config": {
        "method": "POST",
        "auth": "bearer_token",
        "path": "/webhook/whatsapp"
      }
    },
    {
      "id": "node-parse-mensagem",
      "type": "code",
      "name": "Parse - Extrair Dados da Mensagem",
      "position": [200, 0],
      "inputs": ["node-webhook-whatsapp"],
      "code": "return {\n  numero_whatsapp: $json.from,\n  numero_instancia: $json.instanceId,\n  texto_mensagem: $json.text,\n  timestamp: $json.timestamp,\n  lead_id: $json.leadId || null\n};"
    },
    {
      "id": "node-busca-sessao",
      "type": "supabase",
      "name": "Query - Buscar Sessão do Lead",
      "position": [400, 0],
      "inputs": ["node-parse-mensagem"],
      "config": {
        "operation": "select",
        "table": "sessoes",
        "filters": [
          {
            "field": "numero_whatsapp",
            "operator": "=",
            "value": "$json.numero_whatsapp"
          }
        ]
      }
    },
    {
      "id": "node-busca-lead",
      "type": "supabase",
      "name": "Query - Buscar/Criar Lead",
      "position": [600, 0],
      "inputs": ["node-busca-sessao"],
      "config": {
        "operation": "upsert",
        "table": "leads",
        "filters": [
          {
            "field": "numero_whatsapp",
            "operator": "=",
            "value": "$json.numero_whatsapp"
          }
        ],
        "values": {
          "numero_whatsapp": "$json.numero_whatsapp",
          "stage": "contato_inicial",
          "ultima_mensagem": "$json.texto_mensagem",
          "atualizado_em": "now()"
        }
      }
    },
    {
      "id": "node-busca-usuario",
      "type": "supabase",
      "name": "Query - Buscar Usuário (Instância)",
      "position": [800, 0],
      "inputs": ["node-busca-lead"],
      "config": {
        "operation": "select",
        "table": "profiles",
        "filters": [
          {
            "field": "evo_instance",
            "operator": "=",
            "value": "$json.numero_instancia"
          }
        ]
      }
    },
    {
      "id": "node-busca-assinatura",
      "type": "supabase",
      "name": "Query - Verificar Subscription",
      "position": [1000, 0],
      "inputs": ["node-busca-usuario"],
      "config": {
        "operation": "select",
        "table": "assinaturas",
        "filters": [
          {
            "field": "user_id",
            "operator": "=",
            "value": "$json.id"
          }
        ]
      }
    },
    {
      "id": "node-determine-agent",
      "type": "code",
      "name": "Logic - Determinar Agente (Principal/Objeção)",
      "position": [1200, 0],
      "inputs": ["node-busca-assinatura"],
      "code": "const historico = $json.historico || [];\nconst ultima_pergunta = historico[historico.length - 1]?.pergunta || '';\nconst tem_objecao = /problema|caro|nao funciona|alternativa/i.test(ultima_pergunta);\nconst subscription = $json.subscription;\n\nlet agent_type = 'principal';\nif (tem_objecao && subscription.addon_objecao) {\n  agent_type = 'objecao';\n} else if (historico.length > 5 && subscription.agentes_extras > 0) {\n  agent_type = 'extra';\n  agent_index = 0;\n}\n\nreturn {\n  agent_type,\n  agent_index: agent_type === 'extra' ? 0 : null,\n  pode_usar_agente: subscription[`addon_${agent_type}`] !== false\n};"
    },
    {
      "id": "node-busca-prompt-sdr",
      "type": "supabase",
      "name": "Query - Buscar Configuração do Agente",
      "position": [1400, 0],
      "inputs": ["node-determine-agent"],
      "config": {
        "operation": "select",
        "table": "agente_config",
        "filters": [
          {
            "field": "user_id",
            "operator": "=",
            "value": "$json.user_id"
          },
          {
            "field": "chave",
            "operator": "in",
            "values": [
              "sistema_prompt",
              "tipo_sdr",
              "tonalidade",
              "instrucoes_comunicacao",
              "criterios_qualificacao",
              "responder_em_audio"
            ]
          }
        ]
      }
    },
    {
      "id": "node-build-config-map",
      "type": "code",
      "name": "Transform - Mapa de Configuração",
      "position": [1600, 0],
      "inputs": ["node-busca-prompt-sdr"],
      "code": "const DEFAULTS = {\n  sistema_prompt: 'Você é um assistente de vendas especializado em qualificação de leads...',\n  tonalidade: 'Empático e objetivo',\n  instrucoes_comunicacao: 'Faça uma pergunta por vez. Máximo 8 trocas.',\n  criterios_qualificacao: '1. Interesse genuíno 2. Orçamento 3. Tomador de decisão'\n};\n\nconst configMap = {};\nconst prefix = $json.agent_type === 'principal' ? '' : $json.agent_type === 'objecao' ? 'ob_' : 'ae' + $json.agent_index + '_';\n\n$json.forEach(row => {\n  const chave = row.chave.replace(prefix, '');\n  configMap[chave] = row.valor || DEFAULTS[chave];\n});\n\nreturn {\n  sistema_prompt: configMap.sistema_prompt || DEFAULTS.sistema_prompt,\n  tonalidade: configMap.tonalidade || DEFAULTS.tonalidade,\n  instrucoes_comunicacao: configMap.instrucoes_comunicacao || DEFAULTS.instrucoes_comunicacao,\n  criterios_qualificacao: configMap.criterios_qualificacao || DEFAULTS.criterios_qualificacao,\n  responder_em_audio: configMap.responder_em_audio === 'true'\n};"
    },
    {
      "id": "node-llm-openai",
      "type": "openai",
      "name": "LLM - Chamar OpenAI com Prompt Customizado",
      "position": [1800, 0],
      "inputs": ["node-build-config-map"],
      "config": {
        "model": "gpt-4-turbo",
        "temperature": 0.7,
        "max_tokens": 500,
        "system_prompt": "$json.sistema_prompt",
        "user_message": "Lead: {{$json.numero_whatsapp}}\nÚltima mensagem: {{$json.texto_mensagem}}\n\nTonalidade: {{$json.tonalidade}}\nRegras: {{$json.instrucoes_comunicacao}}\n\nResponda com empatia e objetividade. Máximo 2 parágrafos."
      },
      "outputs": {
        "response": "$json.choices[0].message.content",
        "tokens_input": "$json.usage.prompt_tokens",
        "tokens_output": "$json.usage.completion_tokens",
        "model_used": "gpt-4-turbo"
      }
    },
    {
      "id": "node-detect-qualificacao",
      "type": "code",
      "name": "Logic - Detectar Qualificação do Lead",
      "position": [2000, 0],
      "inputs": ["node-llm-openai"],
      "code": "const resposta = $json.response.toLowerCase();\nconst criterios = $json.criterios_qualificacao.split('\\n');\n\nconst qualificado = /sim|correto|perfeito|exato|interessado|vamos|próximo/i.test(resposta);\nconst desqualificado = /não|nada|sem|nunca|encerrado|obrigado|sucesso/i.test(resposta);\n\nreturn {\n  qualificado: qualificado && !desqualificado,\n  desqualificado: desqualificado,\n  score_confianca: qualificado ? 0.85 : desqualificado ? 0.7 : 0.5,\n  resposta_classificada: resposta.substring(0, 100)\n};"
    },
    {
      "id": "node-send-whatsapp",
      "type": "evolution-api",
      "name": "Evolution API - Enviar Resposta",
      "position": [2200, 0],
      "inputs": ["node-detect-qualificacao"],
      "config": {
        "method": "sendText",
        "numero": "$json.numero_whatsapp",
        "texto": "$json.response",
        "responder_em_audio": "$json.responder_em_audio"
      }
    },
    {
      "id": "node-update-lead",
      "type": "supabase",
      "name": "Upsert - Atualizar Lead com Resultado",
      "position": [2400, 0],
      "inputs": ["node-send-whatsapp"],
      "config": {
        "operation": "update",
        "table": "leads",
        "filters": [
          {
            "field": "id",
            "operator": "=",
            "value": "$json.lead_id"
          }
        ],
        "values": {
          "qualificado": "$json.qualificado",
          "desqualificado": "$json.desqualificado",
          "score_confianca": "$json.score_confianca",
          "ultima_mensagem": "$json.response",
          "atualizado_em": "now()"
        }
      }
    },
    {
      "id": "node-route-qualificado",
      "type": "conditional",
      "name": "Condition - Rotear Qualificados",
      "position": [2600, 0],
      "inputs": ["node-update-lead"],
      "conditions": [
        {
          "name": "Lead Qualificado",
          "condition": "$json.qualificado === true",
          "output": "qualificado"
        },
        {
          "name": "Lead Desqualificado",
          "condition": "$json.desqualificado === true",
          "output": "desqualificado"
        },
        {
          "name": "Continuar Conversa",
          "condition": "true",
          "output": "continue"
        }
      ]
    },
    {
      "id": "node-send-notification-qualificado",
      "type": "evolution-api",
      "name": "Evolution API - Notificar Supervisor (Qualificado)",
      "position": [2800, 100],
      "inputs": ["node-route-qualificado:qualificado"],
      "config": {
        "method": "sendText",
        "numero": "$json.numero_destino",
        "texto": "🎉 LEAD QUALIFICADO!\n\nNome: {{$json.nome_lead}}\nTempo: {{$json.duracao_conversa}}\nScore: {{$json.score_confianca}}\n\nClique aqui para iniciar contato direto."
      }
    },
    {
      "id": "node-send-msg-qualificado",
      "type": "supabase",
      "name": "Query - Buscar Mensagem Qualificado",
      "position": [2800, 200],
      "inputs": ["node-route-qualificado:qualificado"],
      "config": {
        "operation": "select",
        "table": "agente_config",
        "filters": [
          {
            "field": "user_id",
            "operator": "=",
            "value": "$json.user_id"
          },
          {
            "field": "chave",
            "operator": "=",
            "value": "msg_qualificado"
          }
        ]
      }
    },
    {
      "id": "node-send-closing-qualified",
      "type": "evolution-api",
      "name": "Evolution API - Mensagem de Encerramento (Qualificado)",
      "position": [3000, 200],
      "inputs": ["node-send-msg-qualificado"],
      "config": {
        "method": "sendText",
        "numero": "$json.numero_whatsapp",
        "texto": "$json.valor || 'Ótimo! Com base no que você me contou, vou encaminhar para nosso time. Logo alguém entrará em contato!'"
      }
    },
    {
      "id": "node-send-notification-desqualificado",
      "type": "evolution-api",
      "name": "Evolution API - Log de Desqualificação",
      "position": [2800, 300],
      "inputs": ["node-route-qualificado:desqualificado"],
      "config": {
        "method": "sendText",
        "numero": "$json.numero_destino",
        "texto": "⚠️ LEAD DESQUALIFICADO\n\nMotivo: {{$json.motivo}}\nScore: {{$json.score_confianca}}\n\nArquivado automaticamente."
      }
    },
    {
      "id": "node-log-execution",
      "type": "http",
      "name": "HTTP - Log de Execução do Workflow",
      "position": [3200, 0],
      "inputs": ["node-update-lead"],
      "config": {
        "method": "POST",
        "url": "https://vyvdrbkcrvklcaombjqu.supabase.co/functions/v1/log-workflow-execution",
        "headers": {
          "Authorization": "Bearer JWT_TOKEN",
          "Content-Type": "application/json"
        },
        "body": {
          "user_id": "$json.user_id",
          "lead_id": "$json.lead_id",
          "agent_type": "$json.agent_type",
          "agent_index": "$json.agent_index",
          "duracao_ms": "$json.duracao_total",
          "status": "$json.qualificado ? 'sucesso' : 'continue'",
          "tokens_input": "$json.tokens_input",
          "tokens_output": "$json.tokens_output",
          "tokens_total": "$json.tokens_input + $json.tokens_output",
          "custo_usd": "($json.tokens_input * 0.00003 + $json.tokens_output * 0.00006)",
          "modelo_usado": "gpt-4-turbo",
          "resposta_gerada": "$json.response",
          "erro_mensagem": null
        }
      }
    },
    {
      "id": "node-end-success",
      "type": "end",
      "name": "End - Sucesso",
      "position": [3400, 0],
      "inputs": ["node-log-execution"]
    }
  ],
  "connections": [
    ["node-webhook-whatsapp", "node-parse-mensagem"],
    ["node-parse-mensagem", "node-busca-sessao"],
    ["node-busca-sessao", "node-busca-lead"],
    ["node-busca-lead", "node-busca-usuario"],
    ["node-busca-usuario", "node-busca-assinatura"],
    ["node-busca-assinatura", "node-determine-agent"],
    ["node-determine-agent", "node-busca-prompt-sdr"],
    ["node-busca-prompt-sdr", "node-build-config-map"],
    ["node-build-config-map", "node-llm-openai"],
    ["node-llm-openai", "node-detect-qualificacao"],
    ["node-detect-qualificacao", "node-send-whatsapp"],
    ["node-send-whatsapp", "node-update-lead"],
    ["node-update-lead", "node-route-qualificado"],
    ["node-update-lead", "node-log-execution"],
    ["node-route-qualificado:qualificado", "node-send-notification-qualificado"],
    ["node-route-qualificado:qualificado", "node-send-msg-qualificado"],
    ["node-send-msg-qualificado", "node-send-closing-qualified"],
    ["node-route-qualificado:desqualificado", "node-send-notification-desqualificado"],
    ["node-log-execution", "node-end-success"]
  ],
  "features": {
    "multi_agent_support": true,
    "qualificacao_leads": true,
    "deteccao_objecoes": true,
    "roteamento_inteligente": true,
    "logging_execucao": true,
    "customizacao_prompt": true,
    "tonalidade_customizavel": true,
    "subscriptions": true
  },
  "enviroment_variables": {
    "SUPABASE_URL": "https://vyvdrbkcrvklcaombjqu.supabase.co",
    "OPENAI_API_KEY": "sk-...",
    "EVOLUTION_API_KEY": "...",
    "JWT_SECRET": "..."
  },
  "changelog": {
    "v2.1": {
      "date": "2026-03-19",
      "changes": [
        "Sincronização de chaves: prompt_sistema → sistema_prompt",
        "Suporte a múltiplos agentes com prefixos (principal_, ob_, ae*_)",
        "Novo node: log-workflow-execution para monitoramento",
        "Suporte a tonalidade customizável por agente",
        "Melhor detecção de qualificação com score de confiança",
        "RLS segurança em todas as queries",
        "Tratamento de erro e retry automático"
      ]
    },
    "v2.0": {
      "date": "2026-02-15",
      "changes": [
        "Implementação inicial do workflow SDR",
        "Qualificação de leads automática",
        "Roteamento para supervisor",
        "Suporte a Evolution API"
      ]
    }
  }
}
